<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BrandCoralColor">#FFB8563D</Color>
    <Color x:Key="BrandSageColor">#FF64796B</Color>
    <Color x:Key="BrandInkColor">#FF172123</Color>
    <Color x:Key="BrandSandColor">#FFF4EEE4</Color>
    <Color x:Key="BrandMintColor">#FFDCE9E1</Color>

    <SolidColorBrush x:Key="BrandCoralBrush" Color="{StaticResource BrandCoralColor}" />
    <SolidColorBrush x:Key="BrandSageBrush" Color="{StaticResource BrandSageColor}" />
    <SolidColorBrush x:Key="BrandInkBrush" Color="{StaticResource BrandInkColor}" />
    <SolidColorBrush x:Key="BrandSandBrush" Color="{StaticResource BrandSandColor}" />
    <SolidColorBrush x:Key="BrandMintBrush" Color="{StaticResource BrandMintColor}" />

    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FFF7F2EA" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#CCFFFDFC" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#B3FFFFFF" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#FF5D686A" />
    <SolidColorBrush x:Key="StrokeSoftBrush" Color="#1C172123" />

    <Thickness x:Key="PagePadding">28</Thickness>
    <CornerRadius x:Key="CardCornerRadius">24</CornerRadius>

    <Style x:Key="HeroTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="Foreground" Value="{StaticResource BrandInkBrush}" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BrandInkBrush}" />
    </Style>

    <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Foreground" Value="{StaticResource BrandSageBrush}" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
        <Setter Property="Padding" Value="22" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="{StaticResource BrandCoralBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="18,10" />
    </Style>

    <Style x:Key="SubtleButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="{StaticResource BrandMintBrush}" />
        <Setter Property="Foreground" Value="{StaticResource BrandInkBrush}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="16,10" />
    </Style>
</ResourceDictionary>

