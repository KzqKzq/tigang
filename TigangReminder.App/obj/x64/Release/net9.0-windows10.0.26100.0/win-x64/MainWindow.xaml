<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TigangReminder_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="提肛节律"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:ConnectionId='2' x:Name="RootLayout" Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:ConnectionId='3' x:Name="AppTitleBar" Title="提肛节律">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <TabView x:ConnectionId='4'
            x:Name="RootTabs"
            Grid.Row="1"
            Margin="20"
            CanDragTabs="False"
            CanReorderTabs="False"
            TabWidthMode="Equal">

            <TabViewItem Header="总览">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="18" Padding="8">
                        <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource BrandSandBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="Win11 Native Daily Flow" />
                                <TextBlock Style="{StaticResource HeroTitleTextStyle}" Text="把提肛提醒、训练节律和恢复习惯放进一个原生 Win11 应用里。" />
                                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="支持系统通知、后台常驻、AI 计划建议和训练完成统计。" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button Command="{Binding StartTrainingCommand}" Content="开始训练" Style="{StaticResource AccentButtonStyle}" />
                                    <Button Command="{Binding TestToastCommand}" Content="测试通知" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button x:ConnectionId='12'                           Content="隐藏到托盘" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="下一次提醒" />
                                    <TextBlock Margin="0,8,0,0" FontSize="20" FontWeight="SemiBold" Text="{Binding NextReminderSummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="启用中的计划" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Text="{Binding ActivePlanCount}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="累计完成" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Text="{Binding TotalSessionsCompleted}" />
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{Binding LastCompletedText}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="连续天数 / 总分钟" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Text="{Binding CurrentStreakDays}" />
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{Binding TotalMinutesSummary}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="0.8*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="14">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="即将到来的提醒" />
                                    <ListView ItemsSource="{Binding UpcomingReminders}" SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock FontSize="17" FontWeight="SemiBold" Text="{Binding PlanName}" />
                                                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{Binding WhenText}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource BrandSageBrush}" Text="{Binding RelativeText}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="14">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="最近训练记录" />
                                    <ListView ItemsSource="{Binding SessionHistory}" SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Padding="0,8">
                                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Summary}" />
                                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{Binding CompletedText}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="计划">
                <Grid ColumnSpacing="16" Padding="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="提醒计划" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Command="{Binding AddPlanCommand}" Content="新增计划" Style="{StaticResource AccentButtonStyle}" />
                                <Button Command="{Binding DeletePlanCommand}" Content="删除" Style="{StaticResource SubtleButtonStyle}" />
                            </StackPanel>
                            <ListView ItemsSource="{Binding Plans}" SelectedItem="{Binding SelectedPlan, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,12"
                                            Padding="14"
                                            Background="{StaticResource PanelBackgroundBrush}"
                                            BorderBrush="{StaticResource StrokeSoftBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                            <StackPanel Spacing="6">
                                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Name}" />
                                                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{Binding Description}" TextWrapping="Wrap" />
                                                <TextBlock Foreground="{StaticResource BrandSageBrush}" Text="{Binding ReminderSummary}" />
                                                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{Binding DurationSummary}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="18">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="计划细节" />
                                <ToggleSwitch Header="启用当前计划" IsOn="{Binding SelectedPlan.IsEnabled, Mode=TwoWay}" />
                                <TextBox Header="计划名称" Text="{Binding SelectedPlan.Name, Mode=TwoWay}" />
                                <TextBox Header="说明" Text="{Binding SelectedPlan.Description, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" />

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <NumberBox Grid.Column="0" Header="收紧秒数" Minimum="2" Maximum="20" SpinButtonPlacementMode="Inline" Value="{Binding SelectedPlan.ContractSeconds, Mode=TwoWay}" />
                                    <NumberBox Grid.Column="1" Header="放松秒数" Minimum="2" Maximum="20" SpinButtonPlacementMode="Inline" Value="{Binding SelectedPlan.RelaxSeconds, Mode=TwoWay}" />
                                    <NumberBox Grid.Column="2" Header="轮数" Minimum="4" Maximum="60" SpinButtonPlacementMode="Inline" Value="{Binding SelectedPlan.Cycles, Mode=TwoWay}" />
                                </Grid>

                                <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="每周生效日" />
                                <Grid ColumnSpacing="10" RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton Content="周一" IsChecked="{Binding SelectedPlan.Monday, Mode=TwoWay}" />
                                    <ToggleButton Grid.Column="1" Content="周二" IsChecked="{Binding SelectedPlan.Tuesday, Mode=TwoWay}" />
                                    <ToggleButton Grid.Column="2" Content="周三" IsChecked="{Binding SelectedPlan.Wednesday, Mode=TwoWay}" />
                                    <ToggleButton Grid.Column="3" Content="周四" IsChecked="{Binding SelectedPlan.Thursday, Mode=TwoWay}" />
                                    <ToggleButton Grid.Row="1" Content="周五" IsChecked="{Binding SelectedPlan.Friday, Mode=TwoWay}" />
                                    <ToggleButton Grid.Row="1" Grid.Column="1" Content="周六" IsChecked="{Binding SelectedPlan.Saturday, Mode=TwoWay}" />
                                    <ToggleButton Grid.Row="1" Grid.Column="2" Content="周日" IsChecked="{Binding SelectedPlan.Sunday, Mode=TwoWay}" />
                                </Grid>

                                <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="提醒时间" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBox Width="160" Header="新增时间" Text="{Binding NewReminderTimeText, Mode=TwoWay}" PlaceholderText="HH:mm" />
                                    <Button VerticalAlignment="Bottom" Command="{Binding AddReminderTimeCommand}" Content="添加" Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                                <ListView ItemsSource="{Binding SelectedPlan.ReminderTimes}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="10" Padding="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="220" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Header="提醒时间" Text="{Binding TimeText, Mode=TwoWay}" />
                                                <Button
                                                    Grid.Column="1"
                                                    VerticalAlignment="Bottom"
                                                    Command="{Binding DataContext.RemoveReminderTimeCommand, ElementName=RootLayout}"
                                                    CommandParameter="{Binding}"
                                                    Content="移除" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Command="{Binding SaveNowCommand}" Content="立即保存" Style="{StaticResource AccentButtonStyle}" />
                                    <Button Command="{Binding TestToastCommand}" Content="测试通知" Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabViewItem>

            <TabViewItem x:ConnectionId='5' x:Name="TrainingTab" Header="训练">
                <Grid ColumnSpacing="16" Padding="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Background="{StaticResource BrandSandBrush}">
                        <Grid RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Style="{StaticResource EyebrowTextStyle}" Text="训练节律" />
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding CurrentPhaseText}" />
                                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{Binding CurrentPhaseHint}" TextWrapping="Wrap" />
                            </StackPanel>

                            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse
                                    Width="250"
                                    Height="250"
                                    Fill="{StaticResource BrandMintBrush}"
                                    Opacity="{Binding HaloOpacity}">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform CenterX="125" CenterY="125" ScaleX="{Binding HaloScale}" ScaleY="{Binding HaloScale}" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <Ellipse Width="190" Height="190" Fill="{StaticResource BrandCoralBrush}">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform CenterX="95" CenterY="95" ScaleX="{Binding PulseScale}" ScaleY="{Binding PulseScale}" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                    <TextBlock HorizontalAlignment="Center" FontSize="36" FontWeight="SemiBold" Foreground="White" Text="{Binding RemainingText}" />
                                    <TextBlock HorizontalAlignment="Center" Foreground="White" Text="{Binding CycleText}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="2" Spacing="12">
                                <ProgressBar Minimum="0" Maximum="1" Value="{Binding SessionProgress}" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                    <Button Command="{Binding StartTrainingCommand}" Content="开始训练" Style="{StaticResource AccentButtonStyle}" />
                                    <Button Command="{Binding StopTrainingCommand}" Content="停止" Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="当前计划" />
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedPlan.Name}" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{Binding SelectedPlan.Description}" TextWrapping="Wrap" />
                            <TextBlock Foreground="{StaticResource BrandSageBrush}" Text="{Binding SelectedPlan.DurationSummary}" TextWrapping="Wrap" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="收紧阶段保持轻柔上提并自然呼吸；放松阶段完全释放，不持续夹紧。" TextWrapping="Wrap" />
                            <ToggleSwitch Header="降低动画强度" IsOn="{Binding Settings.ReduceMotion, Mode=TwoWay}" />
                            <Button x:ConnectionId='7'                           Content="训练时隐藏到后台" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="AI 工坊">
                <Grid ColumnSpacing="16" Padding="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="AI 计划生成" />
                            <TextBox Header="训练目标" Text="{Binding AiGoalPrompt, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Header="经验等级" SelectedItem="{Binding AiExperienceLevel, Mode=TwoWay}">
                                    <x:String>入门</x:String>
                                    <x:String>稳定期</x:String>
                                    <x:String>进阶</x:String>
                                </ComboBox>
                                <NumberBox Grid.Column="1" Header="可用分钟数" Minimum="3" Maximum="20" Value="{Binding AiAvailableMinutes, Mode=TwoWay}" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Command="{Binding GenerateAiPlanCommand}" Content="生成计划" Style="{StaticResource AccentButtonStyle}" />
                                <Button Command="{Binding ApplyAiPlanCommand}" Content="应用到当前计划" Style="{StaticResource SubtleButtonStyle}" />
                            </StackPanel>
                            <TextBlock Foreground="{StaticResource BrandSageBrush}" Text="{Binding AiStatus}" />
                            <Border Padding="16" Background="{StaticResource BrandSandBrush}" CornerRadius="18">
                                <TextBlock Text="{Binding AiOutput}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="OpenAI 兼容配置" />
                            <TextBox Header="Endpoint" Text="{Binding Settings.AiSettings.Endpoint, Mode=TwoWay}" />
                            <TextBox Header="Model" Text="{Binding Settings.AiSettings.Model, Mode=TwoWay}" />
                            <TextBox Header="API Key" Text="{Binding Settings.AiSettings.ApiKey, Mode=TwoWay}" />
                            <TextBox Header="System Prompt" Text="{Binding Settings.AiSettings.SystemPrompt, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="未配置 API 时会回退到本地建议计划，配置后即可生成真正的 AI 节律建议。" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="18" Padding="8">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="后台与系统交互" />
                                <ToggleSwitch Header="关闭窗口时转入托盘" IsOn="{Binding Settings.CloseToTray, Mode=TwoWay}" />
                                <ToggleSwitch Header="最小化时转入托盘" IsOn="{Binding Settings.MinimizeToTray, Mode=TwoWay}" />
                                <ToggleSwitch Header="降低动画强度" IsOn="{Binding Settings.ReduceMotion, Mode=TwoWay}" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Command="{Binding SaveNowCommand}" Content="保存设置" Style="{StaticResource AccentButtonStyle}" />
                                    <Button x:ConnectionId='6'                           Content="现在隐藏到托盘" Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="说明" />
                                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="MSIX 安装后，计划通知会以 Win11 原生消息形式出现。关闭主窗口后如果启用了托盘常驻，应用会继续留在后台。" TextWrapping="Wrap" />
                                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="当前版本已经支持本地历史统计、AI 计划生成、托盘菜单、通知跳转训练页和计划自动重排。" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>
        </TabView>
    </Grid>
</Window>

